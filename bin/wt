#!/usr/bin/env python3
"""wt — universal git worktree CLI. See SPEC.md."""
from __future__ import annotations

import argparse
import sys
from pathlib import Path

# === config ===

import tomllib
from dataclasses import dataclass, field


class ConfigNotFound(Exception):
    """Raised when no .wt/config.toml is found walking up from start dir."""


class ConfigError(Exception):
    """Raised when .wt/config.toml is malformed or has invalid values."""


@dataclass
class Config:
    repo_root: Path
    worktree_path: str = ".worktrees"
    port_offset_interval: int = 10
    max_slots: int = 20
    name_strategy: str = "cities"
    branch_template: str = "{user}/{name}"
    default_base: str = "origin/main"
    setup: list[str] = field(default_factory=list)
    teardown: list[str] = field(default_factory=list)


_VALID_NAME_STRATEGIES = {"cities", "word_pairs"}


def _find_config_path(start: Path) -> Path:
    """Walk up from `start` until we find `.wt/config.toml` or hit /."""
    current = start.resolve()
    while True:
        candidate = current / ".wt" / "config.toml"
        if candidate.is_file():
            return candidate
        if current.parent == current:
            raise ConfigNotFound(
                f"no .wt/config.toml found walking up from {start}"
            )
        current = current.parent


def _resolve_main_worktree(start: Path, fallback: Path) -> Path:
    """Resolve the main worktree's absolute path, regardless of which
    worktree we're currently in. The main is always the first entry of
    `git worktree list --porcelain`. Falls back to `fallback` if git
    isn't available or `start` isn't inside a repo (e.g. in tests with
    bare tmp dirs)."""
    import subprocess as _sp
    try:
        proc = _sp.run(
            ["git", "worktree", "list", "--porcelain"],
            cwd=start, capture_output=True, text=True, check=True,
        )
    except (_sp.CalledProcessError, FileNotFoundError):
        return fallback
    for line in proc.stdout.splitlines():
        if line.startswith("worktree "):
            return Path(line[len("worktree "):]).resolve()
    return fallback


def load_config(start: Path) -> Config:
    cfg_path = _find_config_path(start)
    # `.wt/config.toml` is committed, so every worktree's checkout contains
    # it — walking up just finds the closest one. But state and project_id
    # must always be keyed off the MAIN worktree so `wt` works the same
    # whether invoked from main or from any linked worktree.
    repo_root = _resolve_main_worktree(start, fallback=cfg_path.parent.parent)

    with cfg_path.open("rb") as f:
        raw = tomllib.load(f)

    cfg = Config(repo_root=repo_root)
    for key in (
        "worktree_path",
        "port_offset_interval",
        "max_slots",
        "name_strategy",
        "branch_template",
        "default_base",
        "setup",
        "teardown",
    ):
        if key in raw:
            setattr(cfg, key, raw[key])

    if cfg.name_strategy not in _VALID_NAME_STRATEGIES:
        raise ConfigError(
            f"invalid name_strategy={cfg.name_strategy!r}; "
            f"expected one of {sorted(_VALID_NAME_STRATEGIES)}"
        )

    if "/" not in cfg.default_base:
        raise ConfigError(
            f"invalid default_base={cfg.default_base!r}; "
            "must be of the form '<remote>/<branch>'"
        )

    return cfg


# === project_id ===

import hashlib
import os


def project_id(repo_root: Path) -> str:
    """Stable, human-readable id for a repo: <basename>-<sha8>."""
    abs_path = str(repo_root.resolve())
    digest = hashlib.sha1(abs_path.encode("utf-8")).hexdigest()[:8]
    return f"{repo_root.name}-{digest}"


def state_paths(pid: str) -> tuple[Path, Path]:
    """Return (state_file, lock_file) paths under ~/.wt/."""
    base = Path(os.environ["HOME"]) / ".wt"
    return base / f"{pid}.json", base / f"{pid}.lock"


# === state ===

import contextlib
import fcntl
import json


class SlotsFull(Exception):
    """Raised when no free slot is available within max_slots."""


@contextlib.contextmanager
def _locked(pid: str):
    state_file, lock_file = state_paths(pid)
    state_file.parent.mkdir(parents=True, exist_ok=True)
    lock_file.touch(exist_ok=True)
    with lock_file.open("w") as lf:
        fcntl.flock(lf.fileno(), fcntl.LOCK_EX)
        try:
            yield
        finally:
            fcntl.flock(lf.fileno(), fcntl.LOCK_UN)


def _empty_state() -> dict:
    return {"version": 1, "project_root": "", "slots": {}}


def load_state(pid: str) -> dict:
    """Read state for `pid`. Returns an empty state shape if missing."""
    state_file, _ = state_paths(pid)
    if not state_file.exists():
        return _empty_state()
    return json.loads(state_file.read_text())


def save_state(pid: str, state: dict) -> None:
    state_file, _ = state_paths(pid)
    state_file.parent.mkdir(parents=True, exist_ok=True)
    tmp = state_file.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(state, indent=2) + "\n")
    tmp.replace(state_file)


def allocate_slot(pid: str, *, max_slots: int, entry: dict) -> int:
    """Acquire flock, find lowest free slot in [1, max_slots], save, return it."""
    with _locked(pid):
        state = load_state(pid)
        used = {int(k) for k in state["slots"]}
        for slot in range(1, max_slots + 1):
            if slot not in used:
                state["slots"][str(slot)] = entry
                save_state(pid, state)
                return slot
        raise SlotsFull(
            f"no free slots (max_slots={max_slots}, used={sorted(used)})"
        )


def free_slot(pid: str, slot: int) -> None:
    with _locked(pid):
        state = load_state(pid)
        state["slots"].pop(str(slot), None)
        save_state(pid, state)


